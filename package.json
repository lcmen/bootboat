{
  "private": true,
  "scripts": {
    "build": "npm run clean && npm run build:css && npm run build:html",
    "build:css": "npx @tailwindcss/cli -i reference/index.css -o dist/index.css --minify",
    "build:html": "mkdir -p dist && cp reference/index.html dist/index.html",
    "clean": "rm -rf dist",
    "dev": "npm run clean && npm run build:html && concurrently npm:watch npm:serve",
    "watch": "npx @tailwindcss/cli -i reference/index.css -o dist/index.css --watch",
    "serve": "npx serve dist -p 8080"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4",
    "@tailwindcss/forms": "^0.5",
    "concurrently": "^9",
    "tailwindcss": "^4"
  }
}
